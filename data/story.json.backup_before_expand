    ]
  },
  "KIRA_CH2_CATACOMBS": {
    "id": "KIRA_CH2_CATACOMBS",
    "character": "KIRA",
    "description": "The catacombs descend for miles beneath the city. The walls are covered in void script\u2014warnings, prophecies, names of the dead.\n\nYou read them as you walk. Your great-grandmother. Your grandfather. All the Nightwinds who came before.\n\nAt the deepest level, you find the chamber: seven pedestals, six empty, one holding a fragment of the crown.\n\nBut a Hollow Knight guards it. Black armor, empty eyes, a sword that drinks light.\n\n'Kira Nightwind,' it speaks with a voice like grinding stones. 'The Master expects you.'",
    "choices": [
      {
        "letter": "A",
        "text": "Fight the Hollow Knight",
        "leads_to": "KIRA_CH2_BATTLE",
        "effects": {
          "void_magic": 2
        },
        "requires": null
