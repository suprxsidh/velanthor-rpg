      }
    ]
  },
  "KIRA_CH2_CROWNHAVEN": {
    "id": "KIRA_CH2_CROWNHAVEN",
    "character": "KIRA",
    "description": "Crownhaven rises before you\u2014a city of a million souls, built on the bones of the old world. The old imperial palace looms over everything, its catacombs a maze of forgotten secrets.\n\nYou have one goal: find the crown piece hidden in the palace. Your parents died protecting its location. Now you must retrieve what they gave their lives to protect.\n\nThe palace is guarded, but you know a way in\u2014through the servants' passages your mother drew in her spellbook.\n\nBelow, in the darkness, something waits.",
    "choices": [
      {
        "letter": "A",
        "text": "Enter through the catacombs",
        "leads_to": "KIRA_CH2_CATACOMBS",
        "effects": {
          "stealth": 1
