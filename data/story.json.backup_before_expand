        "effects": {
          "void_magic": 2
        },
        "requires": null
      }
    ]
  },
  "KIRA_CH1_CROWN_FIRST": {
    "id": "KIRA_CH1_CROWN_FIRST",
    "character": "KIRA",
    "description": "You touch the crown piece, and the world goes silent.\n\nVisions flood your mind: Aethon the Undying, kneeling before an entity beyond comprehension. The Void Beast. A god that eats gods.\n\nAethon shattered his crown to keep it from falling into the Beast's hands. Seven pieces, scattered across time.\n\nBut the pieces call to each other. The Cult has six already. And now, with this seventh...\n\nYou feel the others drawing near. The Cult knows you're here.\n\nThe visions fade, but one thing remains: you now carry two pieces of the crown. And the Beast knows your face.",
    "choices": [
      {
        "letter": "A",
        "text": "Run\u2014while you still can",
        "leads_to": "KIRA_CH2_CROWNHAVEN",
        "effects": {
