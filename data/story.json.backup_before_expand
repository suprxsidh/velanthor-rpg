    ]
  },
  "ELARA_CH2_SURRENDER": {
    "id": "ELARA_CH2_SURRENDER",
    "character": "ELARA",
    "description": "You accept his surrender. A noble's death is too easy\u2014it should be public, messy, remembered.\n\nThe evidence you've gathered goes to the queen's council. Charges of murder, fraud, Cult involvement. Castellan hangs in the public square three weeks later.\n\nBut in his study, you find what you truly sought: the vault key, and a letter explaining everything. Your parents found the crown piece. They tried to destroy it. The Cult killed them for their betrayal.\n\nThe piece is in the vault. And it's calling to you.\n\nYou have your justice. You have your answers. But you still have one choice left: what to do with the crown piece.",
    "choices": [
      {
        "letter": "A",
        "text": "Take the piece\u2014power is yours",
        "leads_to": "ELARA_CH3_TAKE",
        "effects": {
          "intelligence": 1
        },
        "requires": null
      },
      {
        "letter": "B",
